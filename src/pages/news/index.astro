---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const allPosts = await getCollection('news');
const posts = allPosts.sort((a, b) => b.data.date.localeCompare(a.data.date));

const currentPath = '/news';
---

<Layout title="News - BunTool" description="Latest news and updates from BunTool.">
	<Header currentPath={currentPath} />

	<main class="min-h-screen bg-gray-50">
		<section class="py-12">
			<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
				<h1 class="text-4xl font-bold text-gray-900 mb-10">News</h1>

				{posts.length === 0 ? (
					<p class="text-gray-500">No posts yet.</p>
				) : (
					<ul class="space-y-8">
						{posts.map(post => (
							<li>
								<a href={`/news/${post.id}`} class="group block">
									<p class="text-sm text-gray-500 mb-1">{post.data.date}</p>
									<h2 class="text-xl font-semibold text-gray-900 group-hover:text-pink-600 transition">{post.data.title}</h2>
									{post.data.description && (
										<p class="mt-1 text-gray-600">{post.data.description}</p>
									)}
								</a>
							</li>
						))}
					</ul>
				)}
			</div>
		</section>
	</main>

	<Footer />
</Layout>
