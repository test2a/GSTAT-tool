<script>
  const fileTableBody = document.getElementById('file-table-body');
  const step4Choice = document.getElementById('step-4-choice');

  function updateDocState() {
    const hasFiles = fileTableBody.querySelectorAll('tr').length > 0;
    // Toggle empty state and table content visibility
    document.getElementById('file-table-empty')?.classList.toggle('hidden', hasFiles);
    document.getElementById('file-table-content')?.classList.toggle('hidden', !hasFiles);
    // Toggle inactive state on action buttons
    document.querySelectorAll('.btn-needs-docs').forEach(btn => {
      btn.classList.toggle('docs-inactive', !hasFiles);
    });
  }

  const observer = new MutationObserver(updateDocState);

  if (fileTableBody) {
    observer.observe(fileTableBody, { childList: true });
  }

  /*
    NEW FEATURE MODAL LOGIC — uncomment together with the HTML block above
    const newFeatureKey = 'buntool_edit_feature_seen';
    const featureExpiry = new Date('2026-07-01').getTime();
    if (Date.now() < featureExpiry && !localStorage.getItem(newFeatureKey)) {
      document.getElementById('new-feature-modal')?.classList.remove('hidden');
    }
    document.getElementById('new-feature-modal-close')?.addEventListener('click', () => {
      document.getElementById('new-feature-modal')?.classList.add('hidden');
      localStorage.setItem(newFeatureKey, '1');
    });
  */

  // Upload warning modal
  document.getElementById('upload-warning-modal-close')?.addEventListener('click', () => {
    document.getElementById('upload-warning-modal')?.classList.add('hidden');
  });

  // Error modal
  document.getElementById('error-modal-close')?.addEventListener('click', () => {
    document.getElementById('error-modal')?.classList.add('hidden');
  });
  document.getElementById('error-modal-copy-btn')?.addEventListener('click', () => {
    const details = (document.getElementById('error-modal-details') as HTMLTextAreaElement)?.value;
    if (details) navigator.clipboard.writeText(details).catch(() => {});
    const btn = document.getElementById('error-modal-copy-btn');
    if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy details'; }, 2000); }
  });

  // Advanced Settings toggle
  const showAdvancedBtn = document.getElementById('show-advanced-btn');
  const advancedSettings = document.getElementById('advanced-settings');
  const advancedSubmit = document.getElementById('advanced-submit');

  showAdvancedBtn?.addEventListener('click', () => {
    advancedSettings?.classList.remove('hidden');
    advancedSubmit?.classList.remove('hidden');
    step4Choice?.classList.add('hidden');

    // Scroll to advanced settings
    advancedSettings?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // Button groups
  document.querySelectorAll('.btn-group').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.dataset.group;
      document.querySelectorAll(`[data-group="${group}"]`).forEach(b => {
        b.classList.remove('bg-blue-500', 'text-white');
        b.classList.add('bg-white', 'text-gray-700');
      });
      btn.classList.add('bg-blue-500', 'text-white');
      btn.classList.remove('bg-white', 'text-gray-700');
      document.getElementById(`config-${group}`).value = btn.dataset.value;
    });
  });

  // Reset to defaults
  function resetGroup(group, defaultValue) {
    document.querySelectorAll(`[data-group="${group}"]`).forEach(b => {
      const active = b.dataset.value === defaultValue;
      b.classList.toggle('bg-blue-500', active);
      b.classList.toggle('text-white', active);
      b.classList.toggle('bg-white', !active);
      b.classList.toggle('text-gray-700', !active);
    });
    document.getElementById(`config-${group}`).value = defaultValue;
  }

  document.getElementById('reset-advanced-btn')?.addEventListener('click', () => {
    document.getElementById('config-fontFace').value = 'serif';
    document.getElementById('config-dateStyle').value = 'DD Mon. YYYY';
    document.getElementById('config-outlineItemStyle').value = 'plain';
    document.getElementById('config-footerFont').value = 'serif';
    document.getElementById('config-numberingStyle').value = 'PageX';
    document.getElementById('config-footerPrefix').value = '';
    resetGroup('headingFontSize', 'medium');
    resetGroup('indexFontSize', 'medium');
    resetGroup('footerFontSize', 'medium');
    resetGroup('alignment', 'right');
    resetGroup('pageNumberColour', 'black');
    document.getElementById('config-showTableBorders').checked = true;
    document.getElementById('config-printableBundle').checked = true;
    if (document.getElementById('config-readability')) document.getElementById('config-readability').checked = false;
    if (document.getElementById('config-autoSplit')) document.getElementById('config-autoSplit').checked = true;
  });

  const DEFAULTS_KEY = 'buntool-default-config';

  function saveDefaultConfig() {
    const d = {
      fontFace: document.getElementById('config-fontFace').value,
      dateStyle: document.getElementById('config-dateStyle').value,
      outlineItemStyle: document.getElementById('config-outlineItemStyle').value,
      footerFont: document.getElementById('config-footerFont').value,
      numberingStyle: document.getElementById('config-numberingStyle').value,
      footerPrefix: document.getElementById('config-footerPrefix').value,
      alignment: document.getElementById('config-alignment').value,
      pageNumberColour: document.getElementById('config-pageNumberColour').value,
      headingFontSize: document.getElementById('config-headingFontSize').value,
      indexFontSize: document.getElementById('config-indexFontSize').value,
      footerFontSize: document.getElementById('config-footerFontSize').value,
      showTableBorders: document.getElementById('config-showTableBorders').checked,
      printableBundle: document.getElementById('config-printableBundle').checked,
      readability: document.getElementById('config-readability')?.checked ?? false,
      autoSplit: document.getElementById('config-autoSplit')?.checked ?? true,
    };
    localStorage.setItem(DEFAULTS_KEY, JSON.stringify(d));
  }

  function loadDefaultConfig() {
    try {
      const stored = localStorage.getItem(DEFAULTS_KEY);
      if (!stored) return;
      const d = JSON.parse(stored);
      if (d.fontFace) document.getElementById('config-fontFace').value = d.fontFace;
      if (d.dateStyle) document.getElementById('config-dateStyle').value = d.dateStyle;
      if (d.outlineItemStyle) document.getElementById('config-outlineItemStyle').value = d.outlineItemStyle;
      if (d.footerFont) document.getElementById('config-footerFont').value = d.footerFont;
      if (d.numberingStyle) document.getElementById('config-numberingStyle').value = d.numberingStyle;
      if (d.footerPrefix !== undefined) document.getElementById('config-footerPrefix').value = d.footerPrefix;
      if (d.alignment) resetGroup('alignment', d.alignment);
      if (d.pageNumberColour) resetGroup('pageNumberColour', d.pageNumberColour);
      if (d.headingFontSize) resetGroup('headingFontSize', d.headingFontSize);
      if (d.indexFontSize) resetGroup('indexFontSize', d.indexFontSize);
      if (d.footerFontSize) resetGroup('footerFontSize', d.footerFontSize);
      if (d.showTableBorders !== undefined) document.getElementById('config-showTableBorders').checked = d.showTableBorders;
      if (d.printableBundle !== undefined) document.getElementById('config-printableBundle').checked = d.printableBundle;
      if (d.readability !== undefined && document.getElementById('config-readability')) document.getElementById('config-readability').checked = d.readability;
      if (d.autoSplit !== undefined && document.getElementById('config-autoSplit')) document.getElementById('config-autoSplit').checked = d.autoSplit;
    } catch (_) {
      // Ignore corrupt/missing storage
    }
  }

  document.getElementById('save-defaults-btn')?.addEventListener('click', () => {
    saveDefaultConfig();
    const btn = document.getElementById('save-defaults-btn');
    btn.textContent = 'Saved!';
    setTimeout(() => { btn.textContent = 'Save settings as defaults for future'; }, 1500);
  });

  document.getElementById('erase-defaults-btn')?.addEventListener('click', () => {
    const btn = document.getElementById('erase-defaults-btn');
    if (localStorage.getItem(DEFAULTS_KEY)) {
      localStorage.removeItem(DEFAULTS_KEY);
      btn.textContent = 'Erased';
      setTimeout(() => { btn.textContent = 'Erase saved defaults'; }, 1500);
    } else {
      btn.textContent = 'Nothing saved';
      setTimeout(() => { btn.textContent = 'Erase saved defaults'; }, 1500);
    }
  });

  window.saveDefaultConfig = saveDefaultConfig;
  window.hasDefaultConfig = () => !!localStorage.getItem(DEFAULTS_KEY);

  loadDefaultConfig();
  updateDocState();
</script>

