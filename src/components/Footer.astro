---
import { execSync } from 'child_process';
let commitHash = 'unknown';
try {
  commitHash = execSync('git rev-parse --short HEAD').toString().trim();
} catch {}
---

<footer class="bg-white border-t border-gray-200 mt-auto">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-6">
			<!-- Quick Links -->
			<div>
				<h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Quick Links</h3>
				<ul class="space-y-2">
					<li><a href="/" class="text-sm text-gray-600 hover:text-blue-600 transition">Home</a></li>
					<li><a href="/app" class="text-sm text-gray-600 hover:text-blue-600 transition">Create Bundle</a></li>
					<li><a href="/guide" class="text-sm text-gray-600 hover:text-blue-600 transition">How-to guide</a></li>
				</ul>
			</div>

			<!-- Legal -->
			<div>
				<h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Legal</h3>
				<ul class="space-y-2">
					<li><a href="/legal" class="text-sm text-gray-600 hover:text-blue-600 transition">Privacy</a></li>
					<li><a href="/legal" class="text-sm text-gray-600 hover:text-blue-600 transition">Terms & Conditions</a></li>
					<li><a href="https://github.com/TrisSherliker/buntool2" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 hover:text-blue-600 transition inline-flex items-center">
						Open Source
						<svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
						</svg>
					</a></li>
				</ul>
			</div>

			<!-- contact -->
			<div>
				<h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Support BunTool</h3>
				<ul class="space-y-2">

					<li><a href="/contact" class="text-sm text-gray-600 hover:text-blue-600 transition">Feedback</a></li>
				<li>
					<a href="https://github.com/TrisSherliker/buntool2" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 hover:text-blue-600 transition inline-flex items-center">
					Report a Bug
							<svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
					</a>
				<li>
					<a href="https://ko-fi.com/buntool" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-600 hover:text-blue-600 transition inline-flex items-center">
					Donate to support
							<svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
					</a>				
				</ul>
			</div>

		</div>
		<div class="pt-6 border-t border-gray-200">
			<div class="flex flex-col md:flex-row items-center justify-between space-y-4 md:space-y-0">
				<p class="text-sm text-gray-500">© 2026 Tristan Sherliker <span class="text-xs text-gray-400 ml-2">build {commitHash}</span></p>
				<div class="flex items-center space-x-2 text-sm text-gray-500">
					<svg class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
					</svg>
					<span>100% Private • On-Device Processing</span>
				</div>
			</div>
		</div>
	</div>
</footer>
