---
// Shared header/navigation component
interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex items-center justify-between h-16">
			<!-- Logo -->
			<div class="flex items-center space-x-3">
				<a href="/" class="flex items-center space-x-3 hover:opacity-80 transition">
					<img src="/images/buntool-logo-small.png" alt="BunTool Logo" class="h-10" />
					<div>
						<h1 class="text-xl font-bold text-gray-900">BunTool</h1>
						<p class="text-xs text-gray-500">Court Bundle Creator</p>
					</div>
				</a>
			</div>

			<!-- Desktop Navigation -->
			<nav class="hidden md:flex items-center space-x-10">
				<a
					href="/app"
					class="text-base font-medium px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white rounded-lg transition"
				>
					Make a Bundle
				</a>
				<a
					href="/#features"
					class="text-base font-medium text-gray-600 hover:text-pink-600 transition"
				>
					Features
				</a>
				<a
					href="/#pricing"
					class="text-base font-medium text-gray-600 hover:text-pink-600 transition"
				>
					Pricing
				</a>
				<a
					href="/about"
					class={`text-base font-medium transition ${currentPath === '/about' ? 'text-pink-600' : 'text-gray-600 hover:text-pink-600'}`}
				>
					About
				</a>
				<a
					href="/legal"
					class={`text-base font-medium transition ${currentPath === '/legal' ? 'text-pink-600' : 'text-gray-600 hover:text-pink-600'}`}
				>
					Privacy
				</a>
				<!-- More Info Dropdown -->
				<div class="relative group">
					<button
						type="button"
						class="text-base font-medium text-gray-600 hover:text-pink-600 transition flex items-center space-x-1"
					>
						<span>More Info</span>
						<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
						</svg>
					</button>
					<div class="absolute right-0 mt-2 w-56 rounded-lg shadow-lg bg-white ring-1 ring-black ring-opacity-5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
						<div class="py-2">
							<a href="/news" class="block px-4 py-2 text-base text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition">News</a>
							<a href="/guide" class="block px-4 py-2 text-base text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition">How-to Guide</a>
							<a href="/resources" class="block px-4 py-2 text-base text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition">Other Resources</a>
							<a href="/contact" class="block px-4 py-2 text-base text-gray-700 hover:bg-pink-50 hover:text-pink-600 transition">Contact</a>
						</div>
					</div>
				</div>
			</nav>

			<!-- Mobile menu button -->
			<div class="md:hidden">
				<button id="mobile-menu-button" type="button" class="text-gray-600 hover:text-blue-600 focus:outline-none transition">
					<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
				</button>
			</div>
		</div>
	</div>

	<!-- Mobile Navigation -->
	<div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
		<div class="px-4 py-3 space-y-3">
			<a href="/app" class="block w-full text-center px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white text-sm font-semibold rounded-lg transition">Make a Bundle</a>
			<a href="/#features" class="block text-sm font-medium text-gray-600 hover:text-pink-600 transition">Features</a>
			<a href="/#pricing" class="block text-sm font-medium text-gray-600 hover:text-pink-600 transition">Pricing</a>
			<a href="/about" class="block text-sm font-medium text-gray-600 hover:text-pink-600 transition">About</a>
			<a href="/legal" class="block text-sm font-medium text-gray-600 hover:text-pink-600 transition">Legal</a>
			<div class="pt-2 border-t border-gray-200">
				<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">More Info</p>
				<a href="/news" class="block text-sm font-medium text-gray-600 hover:text-pink-600 transition">News</a>
				<a href="/guide" class="block text-sm font-medium text-gray-600 hover:text-pink-600 transition">How-to Guide</a>
				<a href="/resources" class="block text-sm font-medium text-gray-600 hover:text-pink-600 transition">Other Resources</a>
				<a href="/contact" class="block text-sm font-medium text-gray-600 hover:text-pink-600 transition">Contact</a>
			</div>
		</div>
	</div>
</header>

<script>
	// Mobile menu toggle
	const mobileMenuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');

	mobileMenuButton?.addEventListener('click', () => {
		mobileMenu?.classList.toggle('hidden');
	});
</script>
