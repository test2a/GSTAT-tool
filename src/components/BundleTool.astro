<!-- Error modal -->
<div id="error-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-xl shadow-2xl border border-gray-200 p-6 max-w-lg w-full mx-4 max-h-[90vh] overflow-y-auto">
    <h3 id="error-modal-title" class="text-base font-bold text-gray-800 mb-2">Something went wrong</h3>
    <p id="error-modal-msg" class="text-sm text-gray-700 mb-4 whitespace-pre-line"></p>
    <div id="error-modal-hint" class="hidden mb-4 rounded-lg border-l-4 border-amber-400 bg-amber-50 px-4 py-3">
      <p class="text-sm font-bold text-amber-800 mb-1">&#9888;&#xFE0F; A file has been moved or renamed</p>
      <p class="text-sm text-amber-700">Has a file been moved, renamed, or deleted since it was added? If so, BunTool won't be able to find it in the orginal place. It's usually best to put all files in a single folder when creating a bundle, and to give them useful names (including dates) before adding them.</p>
      <p class="text-sm text-amber-700 mt-1 font-medium">To fix this: remove the affected file from the list and re-add it from its new location.</p>
    </div>
    <div id="error-modal-details-wrapper" class="hidden mb-4">
      <p class="text-xs font-medium text-gray-500 mb-1">Please copy and paste the details below into a bug report email to <a href="mailto:tris@sherliker.net" class="underline">tris@sherliker.net</a>:</p>
      <textarea id="error-modal-details" class="w-full text-xs font-mono bg-gray-50 border border-gray-200 rounded p-2 resize-none focus:outline-none" rows="6" readonly></textarea>
    </div>
    <div class="flex gap-3 justify-end">
      <button id="error-modal-copy-btn" type="button" class="hidden px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition">
        Copy details
      </button>
      <button id="error-modal-close" type="button" class="px-4 py-2 text-sm font-medium text-white bg-pink-500 hover:bg-pink-600 rounded-lg transition">
        Close
      </button>
    </div>
  </div>
</div>

